# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# OpenAI (for classification)
OPENAI_API_KEY=sk-your-openai-api-key

# Inter-service authentication (generate with: openssl rand -hex 32)
API_KEY=your-strong-api-key-here

# Server
PORT=3001

# Error monitoring (optional)
# SENTRY_DSN=https://your-sentry-dsn.ingest.sentry.io/...

# Lease timeouts (minutes)
PROCESSING_LEASE_MINUTES=30
PUBLISHING_LEASE_MINUTES=30

# Pipeline Scheduler (opt-in)
SCHEDULER_ENABLED=false
SCHEDULE_CLASSIFY_MINUTES=30
SCHEDULE_GENERATE_MINUTES=60
SCHEDULE_PUBLISH_MINUTES=120
SCHEDULE_NICHE=health_medicine
GENERATOR_URL=http://localhost:3002
PUBLISHER_URL=http://localhost:3003
GENERATOR_API_KEY=your-generator-api-key
PUBLISHER_API_KEY=your-publisher-api-key
